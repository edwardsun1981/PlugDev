    <USERDEFINES value="_DEBUG"/>
    <SYSDEFINES value="NO_STRICT"/>
    <MAINSOURCE value="PlugProject_dll.bpf"/>
    <INCLUDEPATH value="..\Src;$(BCB)\include;$(BCB)\include\vcl;..;..\..;..\..\..;..\..\..\..;..\..\..\..\..;..\..\..\..\..\.."/>
